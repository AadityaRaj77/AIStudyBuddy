// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Note {
  id        Int      @id @default(autoincrement())
  content   String?
  createdAt DateTime @default(now())

  concepts  Concept[]
  chunks    NoteChunk[]
}

model Concept {
  id        Int      @id @default(autoincrement())
  name      String
  noteId    Int
  strength  Int      @default(0)

  note      Note     @relation(fields: [noteId], references: [id])
  relationsFrom Relationship[] @relation("fromConcept")
  relationsTo   Relationship[] @relation("toConcept")
  
  lastReviewed DateTime?
  nextReview   DateTime?
  interval     Int      @default(1)
}

model Relationship {
  id      Int    @id @default(autoincrement())
  type    String

  fromId  Int
  toId    Int

  from    Concept @relation("fromConcept", fields: [fromId], references: [id])
  to      Concept @relation("toConcept", fields: [toId], references: [id])
}

model QuizResult {
  id        Int      @id @default(autoincrement())
  conceptId Int
  correct   Boolean
  createdAt DateTime @default(now())
}

model NoteChunk {
  id        Int      @id @default(autoincrement())
  noteId    Int
  content   String
  embedding Float[]  // store embedding vector as float array

  note      Note     @relation(fields: [noteId], references: [id])
}